# heavy_search.script — search-focused stress
# Use against: tests/perf_fixtures/wide_medium.json
#
# Stresses: search update on every keystroke, match navigation across
# many hits. Each character of the search query triggers a full content
# rescan in current jiq, so this script directly measures that cost.

# Wait for the file loader; 23 MB large fixture takes a couple of seconds.
wait 3000

# Commit a bounded query so search has finite content to scan. Identity
# on the wide_large fixture would emit ~23 MB of colored output.
text .[0:1000]
wait 200
key enter
wait 5000

key tab
wait 100
key ctrl-f
wait 100

# Type a very common substring character by character so each keystroke
# rescans the full content.
text S
wait 80
text p
wait 80
text r
wait 80
text i
wait 80
text n
wait 80
text g
wait 80

# Walk through many matches in quick succession.
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50
key enter
wait 50

# Backspace through the query — each backspace also rescans.
key backspace
wait 80
key backspace
wait 80
key backspace
wait 80

# Type a different query.
text on
wait 80
text e
wait 200

key esc
wait 100
