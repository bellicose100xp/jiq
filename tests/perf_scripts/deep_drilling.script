# deep_drilling.script — path-at-cursor on nested data
# Use against: tests/perf_fixtures/deep_medium.json
#
# Stresses: recursive path traversal, drill-in/drill-out, json_path
# walks. The deep fixture exists specifically for this script.

# Wait for the file loader; 32 MB large fixture takes a couple of seconds.
wait 3000

# Commit a bounded query so preprocessing has finite work. Identity on
# the deep fixture would emit ~32 MB of colored output and dominate
# preprocessing — not representative of real usage.
text .children[0]
wait 200
key enter
wait 5000

# Drop into results pane.
key tab
wait 100

# Drill in repeatedly. `[` is the typical drill-in shortcut; if the key
# binding differs, edit this script to match.
key down
key down
key down
key down
key down
wait 100

# Walk down several levels.
key pagedown
wait 100
key pagedown
wait 100
key pagedown
wait 100
key pagedown
wait 100

# Single-line moves with each one re-computing path-at-cursor on the
# nested structure.
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
wait 100

# Jump back to top to exercise the line-index lookup.
key home
wait 100
