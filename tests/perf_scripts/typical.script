# typical.script — realistic mixed session
# Use against: tests/perf_fixtures/wide_medium.json
#
# Covers: query debounce, jq spawn + execution, result render, scrolling,
# search update, search navigation, exit.

# Wait for the file loader to deliver input. The 23 MB large fixture
# takes a couple of seconds to read from stdin.
wait 3000

# Type a query character by character. Each char triggers a debounced
# execution attempt; the 50ms gaps stay under the 150ms debounce window
# so only the final form actually runs.
text .[0:100]
wait 200

# Commit the query and wait for jq + preprocessing to complete. On the
# large fixture jq alone takes ~900ms, plus preprocessing on the worker
# thread, plus margin so the perf timers actually record.
key enter
wait 5000

# Drop focus into the results pane and scroll.
key tab
wait 100
key pagedown
wait 100
key pagedown
wait 100
key pagedown
wait 100
key pagedown
wait 100
key down
key down
key down
key down
key down
wait 200

# Open search and look for a known substring from the fixture.
key ctrl-f
wait 100
text Springfield
wait 300

# Walk through several matches.
key enter
wait 100
key enter
wait 100
key enter
wait 100
key enter
wait 100
key enter
wait 200

# Close search. The runner enters drain mode after the last directive
# and waits for in-flight worker work before quitting and dumping perf.
key esc
wait 100
