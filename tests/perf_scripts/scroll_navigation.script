# scroll_navigation.script — scroll-only stress
# Use against: tests/perf_fixtures/wide_medium.json
#
# Stresses: path-at-cursor on every cursor move, render frame, viewport
# slicing. No search, no query — pure result-pane navigation.

# Wait for the file loader; 23 MB large fixture takes a couple of seconds.
wait 3000

# Commit a bounded query so preprocessing has finite work. Identity on
# the wide_large fixture would emit ~23 MB of colored output.
text .[0:1000]
wait 200
key enter
wait 5000

# Drop into results pane.
key tab
wait 100

# Page-by-page descent. Each PageDown moves the viewport and triggers
# path-at-cursor recomputation.
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50
key pagedown
wait 50

# Single-line scrolling — exercises path-at-cursor on every step.
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
key down
wait 100

# Jump to top and back, stresses the line-index lookup at extremes.
key home
wait 100
key end
wait 100
key home
wait 100
