# autocomplete_burst.script — autocomplete suggestion regeneration
# Use against: tests/perf_fixtures/keys_medium.json
#
# Stresses: all_field_names cache, suggestion filter, fuzzy matching.
# The keys fixture has thousands of distinct fields, so each character
# typed in the query forces a heavy filter pass.

# Wait for the file loader; 5.6 MB large fixture takes a moment.
wait 3000

# Trigger field autocomplete by typing `.` then partial field names.
text .
wait 200
text f
wait 100
text i
wait 100
text e
wait 100
text l
wait 100
text d
wait 100
text _
wait 200

# Backspace and retype to hammer the suggestion regeneration.
key backspace
wait 80
key backspace
wait 80
key backspace
wait 80
text l
wait 80
text d
wait 80
text _
wait 80
text 0
wait 200

# Try a different prefix.
key backspace
key backspace
key backspace
key backspace
key backspace
key backspace
key backspace
key backspace
key backspace
wait 200

text .field_005
wait 300
