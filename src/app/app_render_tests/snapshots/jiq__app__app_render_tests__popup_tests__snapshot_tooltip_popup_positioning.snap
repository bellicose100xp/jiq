"│                                                               ╭ fn: map ───────────────────────────────────────────╮ │"
"│                                                               │                                                    │ │"
"│                                                               │ Apply expression to each element of an array       │ │"
"│                                                               │                                                    │ │"
"│                                                               │   map(.name)           │ extract field from each   │ │"
"│                                                               │   map(. + 1)           │ increment each number     │ │"
"│                                                               │   map(select(.active)) │ filter to active items    │ │"
"│                                                               │   map({id, name})      │ reshape each object       │ │"
